# Agent-Server 配置文件示例

server:
  host: "0.0.0.0"
  port: 8080
  read_timeout: 30s
  write_timeout: 30s

control_plane:
  url: "https://control-plane.example.com"
  token: "server-auth-token"
  scope: "default"  # 用于作用域/租户隔离，控制面请求需携带 X-Scope
  timeout: 30s

agent:
  heartbeat_timeout: 60s
  max_connections: 1000
  task_queue_size: 100

logging:
  level: "info"
  dir: "/var/log/agent-server"
  max_size: 100  # MB
  max_files: 10
  max_age: 7     # days

redis:
  enabled: true
  addr: "localhost:6379"
  password: ""
  db: 0

asynq:
  enabled: true
  concurrency: 10
  retry_max: 3
  retry_delay: "1s"
  task_timeout: "5m"

auth:
  shared_secret: ""    # 可选，控制面调用时用于 HMAC 校验
  clock_skew: "300s"   # 允许的时间偏移
  require_signature: false

